  },
  "Security": {
    "Backup": {
      "ScriptPath": "scripts/backup-db.sh",
      "BackupDirectory": "/backups",
      "LogFilePath": "/backups/logs/backup.log",
      "MaxLogLines": 100,
      "TimeoutSeconds": 120
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
