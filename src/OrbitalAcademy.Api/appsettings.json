{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrbitalAcademy": ""
  },
  "Authentication": {
    "JwtBearer": {
      "Enabled": false,
      "Authority": "",
      "Issuer": "",
      "Audience": "",
      "Secret": "",
      "AccessTokenMinutes": 60,
      "RequireHttpsMetadata": true
    },
    "InitialUser": {
      "Enabled": false,
      "Email": "",
      "Nome": "",
      "Papel": "",
      "Unidade": "",
      "Password": ""
    }
  },
  "Cors": {
